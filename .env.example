# Prisma CLI only (generate/migrate/studio). At runtime the app supplies the SQLite path
# programmatically under the storage root, so this value is not used by the running app.
DATABASE_URL="file:./dev.db"

# ── Compute Jobs integration tests ──────────────────────────────────────────────────────────────
# Set RUN_COMPUTE_JOBS=1 to enable gated integration tests that run against a real SSH host.
# These are skipped in CI by default; run them locally with a configured SSH alias.
RUN_COMPUTE_JOBS=

# SSH alias of the test host (must exist in ~/.ssh/config or /etc/ssh/ssh_config).
# The tests call computeProviderId(alias) to derive the provider id — no IP is hardcoded here.
COMPUTE_TEST_SSH_ALIAS=
